<Window x:Class="SmartFocus.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartFocus - Configuración" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="NeonCyan" Color="#00FFFF"/>
        <SolidColorBrush x:Key="BgDark" Color="#0D1117"/>
        <SolidColorBrush x:Key="TextDim" Color="#B0B0B0"/>
    </Window.Resources>
    <Border Background="{StaticResource BgDark}" BorderBrush="{StaticResource NeonCyan}" BorderThickness="1" CornerRadius="8">
        <StackPanel Margin="20">
            <TextBlock Text="Configuración" FontSize="20" Foreground="{StaticResource NeonCyan}" Margin="0,0,0,20"/>

            <!-- Selección de color de acento -->
            <TextBlock Text="Color de acento:" Foreground="{StaticResource TextDim}" Margin="0,5"/>
            <ComboBox x:Name="ColorCombo" SelectionChanged="ColorCombo_SelectionChanged" Margin="0,5,0,15">
                <ComboBoxItem Content="Cian" Tag="#00FFFF"/>
                <ComboBoxItem Content="Verde" Tag="#00FF00"/>
                <ComboBoxItem Content="Rojo" Tag="#FF0000"/>
                <ComboBoxItem Content="Amarillo" Tag="#FFFF00"/>
                <ComboBoxItem Content="Magenta" Tag="#FF00FF"/>
                <Separator/>
                <ComboBoxItem Content="🎨 Personalizado..." Tag="CUSTOM"/>
            </ComboBox>



            <!-- Configuración de hotkey -->
            <TextBlock Text="Hotkey:" Foreground="{StaticResource TextDim}" Margin="0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                <CheckBox x:Name="CtrlCheck" Content="Ctrl" Margin="0,0,10,0" Foreground="White"/>
                <CheckBox x:Name="AltCheck" Content="Alt" Margin="0,0,10,0" Foreground="White"/>
                <CheckBox x:Name="ShiftCheck" Content="Shift" Margin="0,0,10,0" Foreground="White"/>
                <CheckBox x:Name="WinCheck" Content="Win" Margin="0,0,10,0" Foreground="White"/>
                <ComboBox x:Name="KeyCombo" Width="100">
                    <ComboBoxItem Content="A" Tag="A"/>
                    <ComboBoxItem Content="B" Tag="B"/>
                    <ComboBoxItem Content="C" Tag="C"/>
                    <ComboBoxItem Content="F12" Tag="F12"/>
                    <ComboBoxItem Content="Y" Tag="Y"/>
                </ComboBox>
            </StackPanel>

            <!-- Botón Guardar -->
            <Button Content="Guardar" Click="Save_Click" Background="{StaticResource NeonCyan}" Foreground="Black" 
                    FontWeight="Bold" Margin="0,10" Padding="10" BorderThickness="0" Cursor="Hand"/>
            <TextBlock x:Name="StatusText" Foreground="Green" FontSize="12" TextAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>